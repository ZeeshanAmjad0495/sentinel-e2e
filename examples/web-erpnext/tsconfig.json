{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "outDir": "dist",
    "types": ["node", "@playwright/test"],
    // baseUrl is set to "." (this example dir) so that legacy bare imports like
    // `import { env } from "src/config/env"` keep resolving. That override causes
    // the root-relative @sentinele2e/* paths inherited from tsconfig.base.json to
    // misresolve (e.g. to examples/web-erpnext/packages/...). Re-declare them here
    // anchored to this file's baseUrl so they point at the real workspace packages.
    "paths": {
      "@sentinele2e/contracts": ["../../packages/contracts/src/index.ts"],
      "@sentinele2e/contracts/*": ["../../packages/contracts/src/*"],
      "@sentinele2e/core": ["../../packages/core/src/index.ts"],
      "@sentinele2e/core/*": ["../../packages/core/src/*"],
      "@sentinele2e/driver-playwright": [
        "../../packages/driver-playwright/src/index.ts"
      ],
      "@sentinele2e/driver-playwright/*": [
        "../../packages/driver-playwright/src/*"
      ],
      "@sentinele2e/driver-selenium": [
        "../../packages/driver-selenium/src/index.ts"
      ],
      "@sentinele2e/driver-selenium/*": [
        "../../packages/driver-selenium/src/*"
      ],
      "@sentinele2e/ai": ["../../packages/ai/src/index.ts"],
      "@sentinele2e/ai/*": ["../../packages/ai/src/*"]
    }
  },
  "references": [
    { "path": "../../packages/contracts" },
    { "path": "../../packages/core" },
    { "path": "../../packages/driver-playwright" },
    { "path": "../../packages/driver-selenium" },
    { "path": "../../packages/ai" }
  ],
  "include": ["src/**/*.ts", "tests/**/*.ts", "playwright.config.ts"]
}
